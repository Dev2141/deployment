# ═══════════════════════════════════════════════════════════════════════════════
# VIDZAI DEPLOYMENT ENVIRONMENT VARIABLES
# ═══════════════════════════════════════════════════════════════════════════════
# Copy this file to .env and fill in the values from your services
#
# DO NOT COMMIT .env to git - add it to .gitignore
# ═══════════════════════════════════════════════════════════════════════════════

# ───────────────────────────────────────────────────────────────────────────────
# NEO4J AURA (Graph Database)
# ───────────────────────────────────────────────────────────────────────────────
# Get these from: https://neo4j.com/cloud/aura
# 1. Create free instance
# 2. Copy connection details
#
NEO4J_URI=neo4j+s://xxxxxxxxxxx.databases.neo4j.io
NEO4J_USER=neo4j
NEO4J_PASSWORD=your_password_here
NEO4J_DATABASE=neo4j

# ───────────────────────────────────────────────────────────────────────────────
# PINECONE (Vector Database)
# ───────────────────────────────────────────────────────────────────────────────
# Get these from: https://www.pinecone.io
# 1. Create account
# 2. Create index: email-knowledge-graph
# 3. Copy API key and environment
#
PINECONE_API_KEY=your_api_key_here
PINECONE_INDEX=email-knowledge-graph
PINECONE_ENV=prod

# ───────────────────────────────────────────────────────────────────────────────
# LLM / API KEYS
# ───────────────────────────────────────────────────────────────────────────────
# For LLM queries - choose one of:
# - OpenAI API (requires payment)
# - Groq API (free tier available)
# - Ollama (local deployment)
#
LLAMA_API_KEY=your_llm_api_key_here
OPENAI_API_KEY=your_openai_key_here
MODEL_NAME=gpt-oss:120b-cloud

# Optional: Local Ollama endpoint
OLLAMA_BASE_URL=http://localhost:11434

# ───────────────────────────────────────────────────────────────────────────────
# FLASK CONFIG
# ───────────────────────────────────────────────────────────────────────────────
#
FLASK_ENV=production
FLASK_DEBUG=false

# ═══════════════════════════════════════════════════════════════════════════════
# END OF CONFIGURATION
# ═══════════════════════════════════════════════════════════════════════════════
